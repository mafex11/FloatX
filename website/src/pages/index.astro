---
const repo = 'https://github.com/mafex11/FloatX';
const releases = `${repo}/releases`;
const brew = 'brew install mafex11/tap/floatx';
const year = 2026;
const xglyph =
  "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FloatX — your X timeline, floating on screen</title>
    <meta
      name="description"
      content="FloatX floats your X timeline one post at a time in a glass always-on-top widget. Mac app + browser extension. No API, no cost."
    />
    <meta property="og:title" content="FloatX — your X timeline, floating on screen" />
    <meta property="og:description" content="An ambient glass widget that drips your X feed one post at a time. No API, no cost." />
    <meta property="og:image" content="/assets/hero.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="icon"
      href={`data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path transform='translate(2.4,0) scale(0.8)' fill='%23f2f4f7' d='${xglyph}'/><rect x='5' y='21.2' width='14' height='2' rx='1' fill='%231d9bf0'/></svg>`}
    />
  </head>
  <body>
    <div class="bg-glow" aria-hidden></div>

    <nav>
      <a class="brand" href="/">
        <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden>
          <path transform="translate(2.4,0) scale(0.8)" fill="#f2f4f7" d={xglyph} />
          <rect x="5" y="21.2" width="14" height="2" rx="1" fill="#1d9bf0" />
        </svg>
        <span>FloatX</span>
      </a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#install">Install</a>
        <a href={repo} class="ghost-pill">GitHub</a>
      </div>
    </nav>

    <main>
      <!-- HERO -->
      <header class="hero">
        <div class="pill-tag">macOS app · browser extension</div>
        <h1>your X timeline,<br /><span class="grad">floating on screen.</span></h1>
        <p class="sub">
          FloatX drips your feed one post at a time into a small glass window —
          auto-advancing, with hover controls, inline video, and translation.
          <strong>No API. No cost.</strong> It reads your own logged-in session,
          entirely on your machine.
        </p>
        <div class="cta">
          <a class="btn primary" href="#install">Get FloatX</a>
          <a class="btn ghost" href={repo}>View source</a>
        </div>

        <div class="demo">
          <img src="/assets/demo.gif" alt="FloatX in action" loading="eager" />
        </div>
      </header>

      <!-- FEATURES -->
      <section id="features" class="features">
        <h2 class="section-title">Built to live on your screen</h2>
        <div class="grid">
          <div class="card">
            <div class="ic">∞</div>
            <h3>No API, no cost</h3>
            <p>Reads your already-logged-in X session. Nothing to pay for, nothing to authorize, nothing leaves your machine.</p>
          </div>
          <div class="card">
            <div class="ic">◷</div>
            <h3>Ambient by design</h3>
            <p>Auto-advances one post at a time on an interval you set — seconds to hours. Set it and let it drip while you work.</p>
          </div>
          <div class="card">
            <div class="ic">▶</div>
            <h3>Inline video</h3>
            <p>X videos autoplay right in the widget, and the shower waits for them to finish before moving on.</p>
          </div>
          <div class="card">
            <div class="ic">↔</div>
            <h3>Your controls</h3>
            <p>Hover for prev · pause · next. Like and repost in place; reply opens the tweet. Translate non-English posts in a tap.</p>
          </div>
          <div class="card">
            <div class="ic">◳</div>
            <h3>Liquid Glass</h3>
            <p>A native macOS glass widget — resizable (S/M/L/XL), adjustable transparency, and a desktop mode that pins it to your wallpaper.</p>
          </div>
          <div class="card">
            <div class="ic">⌥</div>
            <h3>Always one tap away</h3>
            <p>Lives in the menu bar. Click to float, right-click for settings, or summon it anywhere with a keyboard shortcut.</p>
          </div>
        </div>

        <div class="shots">
          <img src="/assets/hero.png" alt="The glass card" />
          <img src="/assets/controls.png" alt="Hover controls" />
          <img src="/assets/settings.png" alt="Settings" />
          <img src="/assets/feed.png" alt="Feed aware" />
        </div>
      </section>

      <!-- INSTALL -->
      <section id="install" class="install">
        <h2 class="section-title">Install</h2>
        <div class="install-grid">
          <!-- Mac app -->
          <div class="install-card featured">
            <div class="badge-row">
              <h3>Mac app</h3>
              <span class="rec">recommended</span>
            </div>
            <p class="install-desc">
              Native menu-bar app. Fully standalone — no browser needed. Inline
              video, glass UI, resizable. macOS 26+.
            </p>
            <div class="codeblock">
              <code id="brew">{brew}</code>
              <button class="copy" data-copy={brew} aria-label="Copy">Copy</button>
            </div>
            <ol class="steps">
              <li>Run the command above (needs <a href="https://brew.sh">Homebrew</a>).</li>
              <li>Find the <strong>X glyph</strong> in your menu bar.</li>
              <li>Sign in to X once — the window closes itself.</li>
              <li>Click the icon to float your timeline.</li>
            </ol>
            <p class="fineprint">Ad-hoc signed. If Gatekeeper blocks it, right-click the app → Open.</p>
          </div>

          <!-- Extension -->
          <div class="install-card">
            <div class="badge-row">
              <h3>Browser extension</h3>
              <span class="plat">Chrome · Edge</span>
            </div>
            <p class="install-desc">
              Floats your feed in a Picture-in-Picture window. Lighter, but needs
              the browser open (video shows as poster only).
            </p>
            <ol class="steps">
              <li>Download the <a href={releases}>latest zip</a> and unzip it.</li>
              <li>Open <code>chrome://extensions</code>.</li>
              <li>Turn on <strong>Developer mode</strong>.</li>
              <li>Click <strong>Load unpacked</strong>, pick the folder.</li>
              <li>Open <code>x.com</code> → click the pill (or <kbd>⌥⇧X</kbd>).</li>
            </ol>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="foot-inner">
        <div class="foot-brand">
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden>
            <path transform="translate(2.4,0) scale(0.8)" fill="#f2f4f7" d={xglyph} />
            <rect x="5" y="21.2" width="14" height="2" rx="1" fill="#1d9bf0" />
          </svg>
          <span>FloatX</span>
        </div>
        <div class="foot-links">
          <a href={repo}>GitHub</a>
          <a href={releases}>Releases</a>
        </div>
      </div>
      <p class="fine">© {year} · Not affiliated with X Corp. Reads only your own logged-in session.</p>
    </footer>

    <script>
      document.querySelectorAll<HTMLButtonElement>('.copy').forEach((b) => {
        b.addEventListener('click', async () => {
          await navigator.clipboard.writeText(b.dataset.copy || '');
          const t = b.textContent;
          b.textContent = 'Copied';
          b.classList.add('done');
          setTimeout(() => { b.textContent = t; b.classList.remove('done'); }, 1400);
        });
      });
    </script>

    <style is:global>
      :root {
        --bg: #07090d;
        --fg: #e9edf2;
        --muted: #8b98a5;
        --dim: #5b6570;
        --line: rgba(255, 255, 255, 0.08);
        --blue: #1d9bf0;
        --blue2: #4cb8ff;
        --glass: rgba(255, 255, 255, 0.045);
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }

      /* ambient background glow */
      .bg-glow {
        position: fixed; inset: 0; z-index: -1; pointer-events: none;
        background:
          radial-gradient(60% 50% at 50% -5%, rgba(29,155,240,0.22), transparent 60%),
          radial-gradient(40% 40% at 85% 15%, rgba(76,184,255,0.10), transparent 60%),
          linear-gradient(180deg, #0a0e14, #07090d 40%);
      }

      /* nav */
      nav {
        position: sticky; top: 0; z-index: 50;
        display: flex; align-items: center; justify-content: space-between;
        max-width: 1080px; margin: 0 auto; padding: 16px 24px;
        backdrop-filter: blur(12px);
      }
      .brand { display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 17px; }
      .nav-links { display: flex; align-items: center; gap: 22px; font-size: 14px; color: var(--muted); }
      .nav-links a:hover { color: var(--fg); }
      .ghost-pill {
        border: 1px solid var(--line); padding: 7px 14px; border-radius: 9999px;
        background: var(--glass); color: var(--fg) !important;
      }
      .ghost-pill:hover { background: rgba(255,255,255,0.09); }

      main { max-width: 1080px; margin: 0 auto; padding: 0 24px; }

      /* hero */
      .hero { text-align: center; padding: 64px 0 40px; }
      .pill-tag {
        display: inline-block; font-size: 13px; color: var(--blue2);
        border: 1px solid rgba(29,155,240,0.3); background: rgba(29,155,240,0.08);
        padding: 6px 14px; border-radius: 9999px; margin-bottom: 26px;
      }
      h1 {
        font-size: clamp(40px, 7vw, 76px); line-height: 1.02; margin: 0 0 22px;
        letter-spacing: -0.03em; font-weight: 800;
      }
      .grad {
        background: linear-gradient(100deg, var(--blue2), var(--blue));
        -webkit-background-clip: text; background-clip: text; color: transparent;
      }
      .sub { font-size: 19px; color: var(--muted); max-width: 60ch; margin: 0 auto 32px; }
      .sub strong { color: var(--fg); font-weight: 600; }
      .cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 56px; }
      .btn {
        display: inline-block; padding: 13px 30px; border-radius: 9999px;
        font-weight: 700; font-size: 15px; transition: transform .15s, background .2s, box-shadow .2s;
      }
      .btn:hover { transform: translateY(-1px); }
      .btn.primary { background: var(--blue); color: #fff; box-shadow: 0 8px 28px rgba(29,155,240,0.35); }
      .btn.primary:hover { background: var(--blue2); }
      .btn.ghost { border: 1px solid var(--line); background: var(--glass); }
      .btn.ghost:hover { background: rgba(255,255,255,0.09); }

      .demo {
        border-radius: 20px; overflow: hidden;
        border: 1px solid var(--line);
        box-shadow: 0 40px 120px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04);
        background: #0a0d12;
      }
      .demo img { display: block; width: 100%; height: auto; }

      /* sections */
      .section-title {
        font-size: clamp(26px, 4vw, 36px); text-align: center; font-weight: 800;
        letter-spacing: -0.02em; margin: 0 0 40px;
      }
      .features { padding: 96px 0 40px; }

      .grid {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 56px;
      }
      .card {
        background: var(--glass); border: 1px solid var(--line);
        border-radius: 18px; padding: 26px;
        transition: border-color .2s, background .2s, transform .15s;
      }
      .card:hover { border-color: rgba(29,155,240,0.4); background: rgba(255,255,255,0.06); transform: translateY(-2px); }
      .ic {
        width: 40px; height: 40px; border-radius: 11px; margin-bottom: 14px;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(140deg, rgba(76,184,255,0.25), rgba(29,155,240,0.12));
        border: 1px solid rgba(29,155,240,0.25); font-size: 18px; color: var(--blue2);
      }
      .card h3 { margin: 0 0 7px; font-size: 17px; }
      .card p { margin: 0; color: var(--muted); font-size: 14.5px; }

      .shots {
        display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;
      }
      .shots img {
        width: 100%; border-radius: 16px; border: 1px solid var(--line);
        box-shadow: 0 20px 60px rgba(0,0,0,0.45);
      }

      /* install */
      .install { padding: 96px 0 40px; }
      .install-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: start; }
      .install-card {
        background: var(--glass); border: 1px solid var(--line);
        border-radius: 20px; padding: 30px;
      }
      .install-card.featured { border-color: rgba(29,155,240,0.4); background: rgba(29,155,240,0.05); }
      .badge-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
      .badge-row h3 { margin: 0; font-size: 22px; }
      .rec { font-size: 12px; color: var(--blue2); border: 1px solid rgba(29,155,240,0.35);
             padding: 3px 9px; border-radius: 9999px; background: rgba(29,155,240,0.1); }
      .plat { font-size: 12px; color: var(--dim); border: 1px solid var(--line);
              padding: 3px 9px; border-radius: 9999px; }
      .install-desc { color: var(--muted); font-size: 15px; margin: 0 0 18px; }

      .codeblock {
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
        background: #05070a; border: 1px solid var(--line); border-radius: 12px;
        padding: 13px 14px; margin-bottom: 18px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      .codeblock code { font-size: 13.5px; color: var(--blue2); overflow-x: auto; }
      .copy {
        flex-shrink: 0; border: 1px solid var(--line); background: var(--glass); color: var(--fg);
        font-size: 12px; padding: 6px 12px; border-radius: 8px; cursor: pointer; transition: background .2s;
        font-family: inherit;
      }
      .copy:hover { background: rgba(255,255,255,0.1); }
      .copy.done { color: var(--blue2); border-color: rgba(29,155,240,0.4); }

      .steps { padding-left: 20px; margin: 0; color: var(--muted); font-size: 14.5px; }
      .steps li { margin: 8px 0; }
      .fineprint { color: var(--dim); font-size: 13px; margin: 16px 0 0; }
      code, kbd {
        background: rgba(255,255,255,0.07); border: 1px solid var(--line);
        padding: 1px 6px; border-radius: 6px; font-size: 13px;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }

      /* footer */
      footer { border-top: 1px solid var(--line); margin-top: 80px; padding: 36px 24px 60px; }
      .foot-inner {
        max-width: 1080px; margin: 0 auto; display: flex; align-items: center;
        justify-content: space-between; margin-bottom: 16px;
      }
      .foot-brand { display: flex; align-items: center; gap: 8px; font-weight: 700; }
      .foot-links { display: flex; gap: 20px; color: var(--muted); font-size: 14px; }
      .foot-links a:hover { color: var(--fg); }
      .fine { max-width: 1080px; margin: 0 auto; color: var(--dim); font-size: 13px; text-align: center; }

      @media (max-width: 760px) {
        .grid { grid-template-columns: 1fr; }
        .shots { grid-template-columns: 1fr; }
        .install-grid { grid-template-columns: 1fr; }
        .nav-links a:not(.ghost-pill) { display: none; }
      }
    </style>
  </body>
</html>
